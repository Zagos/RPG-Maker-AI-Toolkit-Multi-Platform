{
  "name": "rpgmaker-ai-toolkit-multi-platform",
  "version": "2.1.0",
  "description": "Multi-platform MCP server for RPG Maker MZ, MV, VX Ace, VX and XP",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zagos/RPG-Maker-AI-Toolkit-Multi-Platform.git"
  },
  "homepage": "https://github.com/Zagos/RPG-Maker-AI-Toolkit-Multi-Platform#readme",
  "bugs": {
    "url": "https://github.com/Zagos/RPG-Maker-AI-Toolkit-Multi-Platform/issues"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "launch-game": "node scripts/launch-rpgmaker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rpg-maker",
    "rpg-maker-mz",
    "rpg-maker-mv",
    "rpg-maker-vx-ace",
    "rpg-maker-vx",
    "rpg-maker-xp",
    "ai-toolkit",
    "claude"
  ],
  "author": "Zagos",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "8.46.3",
    "@typescript-eslint/parser": "8.46.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.4"
  }
}
