# Ruta al proyecto de RPG Maker MZ
# Ejemplo: /home/usuario/MiJuegoRPG o C:\Users\usuario\MiJuegoRPG
RPGMAKER_PROJECT_PATH=/ruta/a/tu/proyecto/rpg/maker/mz

# Modo debug (true/false)
MCP_DEBUG=false

# Puerto del servidor MCP (opcional)
MCP_PORT=3000

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=info
