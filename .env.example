# ── Required ────────────────────────────────────────────────────────────────
# Absolute path to your RPG Maker project root
# Linux/Mac: /home/user/Documents/MyGame
# Windows:   C:\Users\user\Documents\MyGame
RPGMAKER_PROJECT_PATH=/path/to/your/rpgmaker/project

# ── Engine selection ─────────────────────────────────────────────────────────
# Which RPG Maker engine the project uses.
# Values: mz | mv | vxace | vx | xp   (default: mz)
RPGMAKER_ENGINE=mz

# ── Optional ────────────────────────────────────────────────────────────────
# Path to the RPG Maker executable (used by the launch-game tool)
# MZ  Windows: C:\Program Files\RPG Maker MZ\RPGMakerMZ.exe
# MV  Windows: C:\Program Files\RPG Maker MV\RPGMakerMV.exe
# VX Ace Mac:  /Applications/RPG VX Ace.app/Contents/MacOS/RPGVXAce
RPGMAKER_EXECUTABLE_PATH=/path/to/RPGMaker

# Ruby executable for VX Ace / VX / XP Marshal bridge
# Only required when RPGMAKER_ENGINE is vxace, vx, or xp
# Default: ruby  (must be on PATH, or set an absolute path)
RUBY_PATH=ruby

# Enable verbose debug output (true/false)
MCP_DEBUG=false

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Maximum number of backup files to keep per JSON file (auto-pruned on write)
BACKUP_MAX_COUNT=10
