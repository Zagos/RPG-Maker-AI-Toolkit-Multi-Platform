# ── Required ────────────────────────────────────────────────────────────────
# Absolute path to your RPG Maker MZ project root
# Linux/Mac: /home/user/Documents/MyGame
# Windows:   C:\Users\user\Documents\MyGame
RPGMAKER_PROJECT_PATH=/path/to/your/rpgmaker/mz/project

# ── Optional ────────────────────────────────────────────────────────────────
# Path to the RPG Maker MZ executable (used by the launch-game tool)
# Windows: C:\Program Files\RPG Maker MZ\RPGMakerMZ.exe
# Mac:     /Applications/RPG Maker MZ.app/Contents/MacOS/RPGMakerMZ
RPGMAKER_EXECUTABLE_PATH=/path/to/RPGMakerMZ

# Enable verbose debug output (true/false)
MCP_DEBUG=false

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Maximum number of backup files to keep per JSON file (auto-pruned on write)
BACKUP_MAX_COUNT=10
